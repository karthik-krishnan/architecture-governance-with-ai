# Azure AI Foundry — copy this file to .env and fill in your values
# The .env file is gitignored and never committed.

# Required: base endpoint URL from your Azure AI Foundry project (no trailing slash, no /anthropic suffix)
AZURE_INFERENCE_ENDPOINT=https://<your-project>.services.ai.azure.com

# Required: API key from the same deployment page
AZURE_INFERENCE_KEY=<your-azure-api-key>

# Optional: model name exactly as shown in Azure AI Foundry → Models + endpoints (default: claude-3-7-sonnet)
AZURE_INFERENCE_MODEL=claude-3-7-sonnet

# Optional: how many times the agent retries if generated tests fail to compile (default: 3)
MAX_COMPILE_ITERATIONS=3
